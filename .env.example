# Copy to .env for local runs. On Railway these are set in the service "Variables".

# PostgreSQL connection string.
# On Railway: add a Postgres database to the project and reference ${{Postgres.DATABASE_URL}}.
DATABASE_URL=

# Resend API key — create one at https://resend.com/api-keys
RESEND_API_KEY=

# Sender + internal notification addresses.
# LEAD_FROM_EMAIL must be on a domain VERIFIED in Resend.
LEAD_FROM_EMAIL="Filo Diretto <noreply@filodiretto.app>"
LEAD_NOTIFY_EMAIL=info@preciseadvertising.tech

# Port the HTTP server listens on (Railway/Render inject this automatically).
PORT=8080
